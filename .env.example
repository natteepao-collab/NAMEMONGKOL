# =============================================
# NAMEMONGKOL - Environment Variables
# คัดลอกไฟล์นี้ไปเป็น .env.local แล้วใส่ค่าจริง
# cp .env.example .env.local
# =============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=https://namemongkol.com

# --- Stripe (Payment) ---
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# --- Slip Verification ---
SLIP2GO_SECRET_KEY=your-slip2go-key
SLIP2GO_ENDPOINT=https://api.slip2go.com

# --- AI / ML ---
GEMINI_API_KEY=your-gemini-key
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# --- LINE Messaging ---
CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
CHANNEL_SECRET=your-line-channel-secret
# LINE_OA_ID=namemongkol
# ADMIN_LINE_ID=your-admin-line-user-id
# NEXT_PUBLIC_LINE_ADD_FRIEND_URL=https://line.me/R/ti/p/@namemongkol
